*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    font-family: Arial, Helvetica, sans-serif;
    line-height: 1.6;

    /* Black background for whole portfolio */
    background-color: black;

    color: white;
    min-height: 100vh;
}

/* HEADER */

header{
    text-align: center;
    padding: 40px 20px;
    color: khaki;
}

header img{
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    border: 5px solid khaki;
    margin-bottom: 20px;
    box-shadow: 0 4px 10px rgba(255,255,255,0.2);
}

header h1{
    font-size: 3rem;
    margin-bottom: 10px;
}

.title{
    font-size: 1.3rem;
    font-weight: bold;
    margin-bottom: 20px;
    color: white;
}

.intro{
    max-width: 900px;
    margin: auto;
    padding: 20px;
}

.intro h2{
    margin-bottom: 15px;
    color: khaki;
}

.intro p{
    margin-bottom: 15px;
    font-size: 1.05rem;
    color: white;
}

/* SECTIONS */

section{
    max-width: 1000px;
    margin: 30px auto;
    padding: 30px;
    background-color: #1a1a1a;
    border-radius: 12px;
    border: 1px solid khaki;
}

section h2{
    margin-bottom: 20px;
    color: khaki;
    font-size: 2rem;
}

/* SKILLS */

#skills ul{
    list-style: square;
    padding-left: 20px;
}

#skills li{
    margin-bottom: 10px;
    font-size: 1.05rem;
    color: white;
}

/* PROJECTS */

.project-card{
    background-color: #262626;
    padding: 20px;
    margin-bottom: 20px;
    border-radius: 10px;
    transition: transform 0.3s ease;
    border-left: 5px solid khaki;
}

.project-card:hover{
    transform: translateY(-5px);
}

.project-card h3{
    margin-bottom: 10px;
    color: khaki;
}

.project-card p{
    color: white;
}

.tags{
    margin-top: 10px;
    font-weight: bold;
    color: khaki;
}

/* CONTACT */

.contact-list{
    list-style: none;
}

.contact-list li{
    margin-bottom: 10px;
}

.contact-list a{
    color: khaki;
    text-decoration: none;
    font-weight: bold;
}

.contact-list a:hover{
    text-decoration: underline;
    color: white;
}

/* FOOTER */

footer{
    text-align: center;
    padding: 20px;
    background-color: #111;
    margin-top: 40px;
    font-size: 1rem;
    color: khaki;
    border-top: 1px solid khaki;
}

/* RESPONSIVE */

@media(max-width:768px){

    header h1{
        font-size: 2rem;
    }

    section{
        margin: 20px;
        padding: 20px;
    }

    header img{
        width: 140px;
        height: 140px;
    }
}
