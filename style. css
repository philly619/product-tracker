:root {
  --bg: #0f1220;
  --bg-soft: #14172a;
  --card: #171a2e;
  --text: #e6e7ef;
  --muted: #a6abbd;
  --brand: #6c63ff;
  --brand-2: #21d4fd;
  --accent: #ff8a00;
  --shadow: 0 10px 30px rgba(0,0,0,0.35);
  --radius: 14px;
  --radius-sm: 10px;
  --radius-lg: 22px;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: "Poppins", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  background: radial-gradient(1200px 800px at 80% -10%, rgba(108,99,255,0.25), transparent 50%),
              radial-gradient(1000px 600px at -10% 10%, rgba(33,212,253,0.18), transparent 50%),
              var(--bg);
  color: var(--text);
  line-height: 1.6;
}

/* Layout helpers */
.container {
  width: min(1120px, 92%);
  margin: 0 auto;
}
.section { padding: 88px 0; }
.grid-2 {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 40px;
}
@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}

/* Header */
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(15,18,32,0.6);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.nav-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
}
.logo {
  font-weight: 700;
  font-size: 1.3rem;
  color: var(--text);
  text-decoration: none;
  letter-spacing: 0.5px;
}
.logo span { color: var(--brand); }

.site-nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  gap: 22px;
}
.site-nav a {
  color: var(--muted);
  text-decoration: none;
  font-weight: 500;
}
.site-nav a:hover,
.site-nav a.active { color: var(--text); }

.hamburger {
  display: none;
  background: none;
  border: 0;
  padding: 8px;
  cursor: pointer;
}
.hamburger span {
  display: block;
  width: 24px; height: 2px;
  background: var(--text);
  margin: 5px 0;
  transition: transform 0.25s ease, opacity 0.25s ease;
}

@media (max-width: 820px) {
  .site-nav {
    position: fixed;
    inset: 60px 0 auto 0;
    background: rgba(15,18,32,0.95);
    padding: 18px 24px;
    transform: translateY(-120%);
    transition: transform 0.3s ease;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .site-nav.open { transform: translateY(0); }
  .site-nav ul { flex-direction: column; gap: 16px; }
  .hamburger { display: block; }
}

/* Hero */
.hero {
  padding-top: 48px;
  position: relative;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: center;
  gap: 40px;
}
@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; }
}
.eyebrow {
  color: var(--brand-2);
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: 0.8rem;
  margin: 0 0 6px;
}
.hero h1 {
  font-size: clamp(2.2rem, 4.5vw, 3.6rem);
  line-height: 1.1;
  margin: 0 0 10px;
}
.subtitle { color: var(--muted); margin-bottom: 22px; }
.hero-cta { display: flex; gap: 12px; margin: 22px 0 24px; }
.socials { display: flex; gap: 16px; }
.social-link {
  color: var(--muted);
  text-decoration: none;
  border-bottom: 1px dashed transparent;
}
.social-link:hover { color: var(--text); border-bottom-color: var(--text); }

.hero-visual .avatar {
  width: 100%;
  max-width: 420px;
  aspect-ratio: 1/1;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
  margin: 0 auto;
  background: linear-gradient(135deg, rgba(108,99,255,0.2), rgba(33,212,253,0.2));
  padding: 10px;
}
.hero-visual img {
  width: 100%; height: 100%; object-fit: cover; border-radius: calc(var(--radius-lg) - 10px);
}

.scroll-indicator {
  position: absolute;
  left: 50%;
  bottom: 18px;
  transform: translateX(-50%);
  color: var(--muted);
  text-decoration: none;
  font-size: 0.9rem;
  opacity: 0.8;
}

/* Buttons */
.btn {
  --btn-bg: var(--bg-soft);
  --btn-fg: var(--text);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 18px;
  border-radius: var(--radius-sm);
  background: var(--btn-bg);
  color: var(--btn-fg);
  border: 1px solid rgba(255,255,255,0.08);
  text-decoration: none;
  transition: transform 0.15s ease, background 0.2s ease, border-color 0.2s ease;
  cursor: pointer;
}
.btn:hover { transform: translateY(-1px); border-color: rgba(255,255,255,0.18); }
.btn.primary { --btn-bg: linear-gradient(135deg, var(--brand), var(--brand-2)); }
.btn.ghost {
  background: transparent;
  border-color: rgba(255,255,255,0.2);
  color: var(--text);
}
.btn.small { padding: 8px 12px; font-size: 0.92rem; }

/* About */
.about .about-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
@media (max-width: 900px) {
  .about .about-cards { grid-template-columns: 1fr; }
}
.about-card {
  background: var(--card);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius);
  padding: 18px;
  box-shadow: var(--shadow);
}
.about-card h3 { margin: 0 0 6px; }

/* Skills */
.skills .skill-list {
  list-style: none; padding: 0; margin: 0;
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
}
@media (max-width: 700px) {
  .skills .skill-list { grid-template-columns: 1fr; }
}
.skill { background: var(--card); border: 1px solid rgba(255,255,255,0.06); padding: 14px; border-radius: var(--radius); }
.skill > span { display: inline-block; margin-bottom: 8px; font-weight: 600; }
.bar {
  background: rgba(255,255,255,0.06);
  border-radius: 999px;
  height: 10px;
  overflow: hidden;
}
.bar span {
  display: block;
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, var(--brand), var(--brand-2));
  border-radius: 999px;
  transition: width 1s ease;
}

/* Projects */
.projects .cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
@media (max-width: 1100px) {
  .projects .cards { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 700px) {
  .projects .cards { grid-template-columns: 1fr; }
}
.card {
  background: var(--card);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  display: grid;
  grid-template-rows: auto 1fr;
}
.card img { width: 100%; display: block; aspect-ratio: 16/10; object-fit: cover; }
.card-body { padding: 16px; }
.card-body h3 { margin: 0 0 6px; }
.card .tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0 14px; }
.card .tags span {
  font-size: 0.8rem; color: var(--muted);
  border: 1px dashed rgba(255,255,255,0.18);
  padding: 4px 8px; border-radius: 999px;
}
.card .actions { display: flex; gap: 10px; }

/* Contact */
.contact-list { list-style: none; padding: 0; margin: 16px 0; color: var(--muted); }
.contact-form {
  background: var(--card);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius);
  padding: 18px;
}
.field { display: grid; gap: 6px; margin-bottom: 14px; }
.field label { font-weight: 600; }
.field input, .field textarea {
  background: var(--bg-soft);
  border: 1px solid rgba(255,255,255,0.08);
  color: var(--text);
  padding: 12px 12px;
  border-radius: 10px;
  outline: none;
}
.field input:focus, .field textarea:focus {
  border-color: rgba(108,99,255,0.6);
  box-shadow: 0 0 0 3px rgba(108,99,255,0.2);
}
.error { color: #ff6b6b; font-size: 0.85rem; min-height: 1.1em; }
.form-status { color: var(--muted); margin-top: 6px; min-height: 1.2em; }

/* Footer */
.site-footer {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 22px 0 36px;
  color: var(--muted);
}
.footer-inner {
  display: flex; align-items: center; justify-content: space-between;
}
.to-top {
  text-decoration: none; color: var(--text);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 6px 10px; border-radius: 10px;
}

/* Reveal on scroll */
.reveal { opacity: 0; transform: translateY(12px); transition: all 0.6s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
